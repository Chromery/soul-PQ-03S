POSTGRES_DB=soul_pq
POSTGRES_USER=soul
POSTGRES_PASSWORD=soul_dev_password
DATABASE_URL=postgresql://soul:soul_dev_password@localhost:5432/soul_pq?schema=public
DATABASE_URL_DOCKER=postgresql://soul:soul_dev_password@postgres:5432/soul_pq?schema=public
DB_PORT=5432
API_PORT=3000
WEB_PORT=8080
CORS_ORIGIN=http://localhost:8080,http://localhost:5173
DEFAULT_TECHNICAL_OWNER="Responsabile tecnico Soul"
ERP_SYNC_TOKEN=
BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_SECONDS=86400

# Backblaze B2 S3-compatible storage.
# Endpoint example: https://s3.us-west-004.backblazeb2.com
S3_ENDPOINT=https://s3.REPLACE_REGION.backblazeb2.com
S3_REGION=REPLACE_REGION
S3_BUCKET=REPLACE_BUCKET_NAME
S3_ACCESS_KEY_ID=REPLACE_B2_KEY_ID
S3_SECRET_ACCESS_KEY=REPLACE_B2_APPLICATION_KEY
S3_FORCE_PATH_STYLE=true
S3_KEY_PREFIX=erp

# OpenRouter vision model used to extract planimetria scale from PDFs.
OPENROUTER_API_KEY=REPLACE_OPENROUTER_API_KEY
OPENROUTER_SCALE_MODEL=qwen/qwen3.5-flash-02-23
OPENROUTER_PDF_ENGINE=mistral-ocr
OPENROUTER_SITE_URL=http://localhost:8080
OPENROUTER_APP_TITLE="Soul Prospect Qualifier"
